#!/bin/bash
# Blocks direct pushes to master — all master changes must go through GitHub UI.
while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/master" ]]; then
    echo ""
    echo "⛔ PUSH BLOCKED: Direct pushes to master are not allowed."
    echo "   Merge to master via the GitHub UI with explicit user approval."
    echo ""
    exit 1
  fi
done
exit 0
