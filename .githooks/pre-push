#!/bin/bash
# Blocks direct pushes to master unless MASTER_OVERRIDE="go master" is set.
while read local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/master" ]]; then
    if [[ "$MASTER_OVERRIDE" == "go master" ]]; then
      echo "Override accepted — pushing to master."
      exit 0
    fi
    echo ""
    echo "⛔ PUSH BLOCKED: Direct pushes to master are not allowed."
    echo "   Set MASTER_OVERRIDE=\"go master\" to override."
    echo ""
    exit 1
  fi
done
exit 0
